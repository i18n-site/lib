c-md, c-md-stream
  display block
  height auto
  width 100%

.Md
  color var(--base-font-color)
  display block
  font-size 16px
  font-weight 400
  word-wrap break-word

  &>*
    animation c-md-fade-in 0.4s cubic-bezier(0.16, 1, 0.3, 1) forwards
    margin var(--mdMargin) 0

  h1, h2, h3, h4, h5, h6
    font-variation-settings 'wght' 200
    font-weight 200

  &>h1:first-child
    margin-top 0

  h1
    font-size 24px

  h2
    font-size 20px

  h3
    font-size 18px

  a
    color #000
    font-variation-settings 'wght' 300
    font-weight 300
    text-decoration none
    transition color 0.3s

    &:hover
      color #00f

  ul, ol
    margin-left 32px
    position relative

  ul>li, ol>li
    align-items flex-start
    display flex
    flex-wrap wrap
    margin calc(var(--mdMargin) * 0.4) 0
    position relative

  ul>li>ul, ol>li>ul, ul>li>ol, ol>li>ol
    width 100%

  ul>li
    &:before
      background currentColor
      content ''
      height 14px
      left -23px
      mask-image var(--mdArrowSvg)
      mask-position center
      mask-repeat no-repeat
      mask-size contain
      opacity 0.5
      position absolute
      top 6px
      width 14px

    &:has(>input[type='checkbox']):before
      display none

    &>input[type='checkbox']
      left -25px
      margin 0
      position absolute
      top 4px

  ol
    counter-reset index

    &>li:before
      align-items center
      background transparent
      border 1px solid currentColor
      border-radius 9px
      content counters(index, '.')
      counter-increment index
      display inline-flex
      font-family c
      font-size 11px
      font-weight 600
      height 18px
      justify-content center
      margin-right 8px
      margin-top 4px
      min-width 18px
      opacity 0.7
      padding 1px 7px 0
      white-space nowrap

  img
    border-radius 12px
    box-shadow 0 8px 30px #00000014
    max-width 100%
    transition transform 0.3s

    &:hover
      transform scale(1.01)

  code
    background linear-gradient(135deg, #ffffffcc, #f5f5f566)
    border 1px solid #00000014
    border-radius calc(var(--mdBorderRadius) * 0.5)
    box-shadow inset 0 0 2px #0000000d
    color inherit
    display inline-block
    font-size 15px
    margin 0 4px
    padding 0 8px
    vertical-align bottom

  hr
    border none

  pre
    background linear-gradient(135deg, #ffffffcc, #f5f5f566)
    border 1px solid #00000014
    border-radius var(--mdBorderRadius)
    box-shadow 0 1px 3px #0000000a
    overflow auto
    padding 12px 18px

    code
      background transparent
      border 0
      box-shadow none
      display block
      padding 0
      vertical-align baseline
      white-space pre
      word-break normal

  table
    background linear-gradient(135deg, #ffffffcc, #f5f5f566)
    border 1px solid #0000001f
    border-collapse separate
    border-radius var(--mdBorderRadius)
    border-spacing 0
    box-shadow 0 0 3px #0000000a inset
    overflow hidden
    width 100%

    th, td
      border-bottom 1px solid #00000014
      border-right 1px solid #00000014
      padding 16px
      text-align left

    th.center, td.center
      text-align center

    th.right, td.right
      text-align right

    th.left, td.left
      text-align left

    th:last-child, td:last-child
      border-right none

    tr:last-child td
      border-bottom none

    thead
      background linear-gradient(135deg, #ffffffe6, #f5f5f580)
      box-shadow 0 0 3px #0000000a inset

  blockquote
    position relative

    &:not(.q)
      padding 4px 0 4px 32px

      p
        line-height 1.5
        margin 4px 0

      &:before
        background var(--mdQuoteSvg) no-repeat left center / contain
        content ''
        height 20px
        left 0
        position absolute
        top 6px
        width 20px

    &.q
      backdrop-filter blur(20px) saturate(180%)
      border 1px solid #0000000f
      border-radius var(--mdBorderRadius)
      box-shadow inset 0 1px 4px #0000000a
      padding 15px 19px 15px 51px

      .qt
        font-size 0
        left 16px
        margin 0
        padding 0
        position absolute
        top 18px

        .qi
          display block
          flex-shrink 0
          height 20px
          mask-position center
          mask-repeat no-repeat
          mask-size contain
          width 20px

      p
        color var(--base-font-color)
        margin 0

        &:not(:last-child)
          margin-bottom 8px

      &.q-note
        background linear-gradient(135deg, #5ac8fa0a, #0071e30f)

        .qi
          background linear-gradient(135deg, #5ac8fa, #0071e3)
          mask-image var(--mdNoteSvg)

      &.q-tip
        background linear-gradient(135deg, #ffd60a0a, #ff9f0a0f)

        .qi
          background linear-gradient(135deg, #ffd60a, #ff9f0a)
          mask-image var(--mdTipSvg)

      &.q-important
        background linear-gradient(135deg, #5856d60d, #5856d604)
        border 1px solid #5856d673
        box-shadow 0 4px 12px #5856d60a, inset 0 1px 4px #5856d60d

        .qi
          background #5856d6
          mask-image var(--mdImportantSvg)

      &.q-warning
        background linear-gradient(135deg, #ff95000d, #ff950004)
        border 1px solid #ff950073
        box-shadow 0 4px 12px #ff95000a, inset 0 1px 4px #ff95000d

        .qi
          background #ff9500
          mask-image var(--mdWarningSvg)

      &.q-caution
        background linear-gradient(135deg, #ff3b300d, #ff3b3004)
        border 1px solid #ff3b3073
        box-shadow 0 4px 12px #ff3b300a, inset 0 1px 4px #ff3b300d

        .qi
          background #ff3b30
          mask-image var(--mdCautionSvg)

  input[type='checkbox']
    appearance none
    background var(--mdTodoSvg) no-repeat center / contain
    cursor default
    flex-shrink 0
    height 18px
    margin-right 8px
    margin-top 4px
    outline none
    width 18px

    &:checked
      background var(--mdDoneSvg) no-repeat center / contain

  th, b, strong
    color #000
    font-variation-settings 'wght' 600
    font-weight 600

.T
  background var(--mdTypingSvg) no-repeat center / contain
  display block
  height 24px
  margin-top 12px
  width 24px