.BtnC.lang .Ico
  background-image var(--i18nSvg)
  background-size 20px
  filter opacity(0.8)
  height 100%
  width 100%

.I18n.Lg
  border-radius 16px
  box-sizing border-box
  display flex
  flex-direction column
  max-width 650px
  min-width 300px
  padding 24px

  &>h6
    color #1d1d1f
    font-size 18px
    font-weight 600
    margin 0
    text-align center

  &>b
    display flex
    flex-wrap wrap
    gap 8px
    justify-content center

    .Btn
      font-size 12px
      --btnPadding 6px 12px
      --btnRadius 8px