.demo
  align-items center
  box-sizing border-box
  display flex
  flex-direction column
  gap 20px
  margin 40px auto
  max-width 650px
  padding 32px
  width 100%

  h2
    color #1d1d1f
    font-size 18px
    font-weight 600
    text-align center

  &>b
    align-items center
    backdrop-filter blur(10px)
    background #ffffff66
    border 1px solid #0000000d
    border-radius 16px
    box-sizing border-box
    display flex
    flex-direction column
    gap 16px
    padding 24px
    width 100%

    p
      color #666
      font-size 14px
      margin 0