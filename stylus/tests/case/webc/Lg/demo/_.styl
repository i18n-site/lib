.demo
  box-sizing border-box
  display flex
  flex-direction column
  gap 20px
  margin 0 auto
  max-width 480px
  padding 24px
  width 100%

  h2
    color #1d1d1f
    font-size 15px
    font-weight 600
    margin 12px 0 0

  article.Lg
    border-radius 24px
    box-shadow 0 8px 32px #0000000a
    box-sizing border-box
    display flex
    flex-direction column
    gap 12px
    padding 24px
    width 100%

    h3
      color #1d1d1f
      font-size 16px
      font-weight 600
      margin 0

    p
      color #515154
      font-size 14px
      line-height 1.5
      margin 0