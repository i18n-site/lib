.Lg, .Btn, .BtnC, .Input
  display flex
  flex-direction column
  position relative
  z-index 1

.Lg::before, .Btn::before, .BtnC::before, .Input::before
  backdrop-filter blur(8px) saturate(150%)
  border-radius inherit
  content ''
  inset 0
  position absolute
  z-index -1

.Lg::after, .Btn::after, .BtnC::after, .Input::after
  background-clip border-box
  background-image linear-gradient(180deg, #00000026, #0000000f)
  background-origin border-box
  border 1px solid transparent
  border-radius inherit
  border-width 0.5px
  content ''
  inset 0
  mask-clip content-box, border-box
  mask-composite exclude
  mask-image linear-gradient(#fff 0 0), linear-gradient(#fff 0 0)
  pointer-events none
  position absolute
  z-index -1

main.Lg
  border-radius 24px
  gap var(--gap)
  margin var(--gap)
  max-width 480px
  padding var(--gap)
  text-align center