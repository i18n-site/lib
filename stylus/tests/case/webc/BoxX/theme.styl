dialog.Box>.aX
  align-items center
  background #fff
  border none
  border-radius 50%
  bottom -32px
  box-shadow inset 0 4px 12px #ffffff66, inset 0 -2px 6px #0000000d, inset 0 0 0 1px #0000001a, inset 0 0 3px #0000003a
  cursor pointer
  display flex
  height 32px
  justify-content center
  left 50%
  margin-left -16px
  position absolute
  transition all 0.4s cubic-bezier(0.15, 1, 0.3, 1)
  width 32px
  z-index 1

  &::before
    background var(--boxXSvg) center / 16px no-repeat
    content ''
    inset 0
    pointer-events none
    position absolute
    transition all 0.4s cubic-bezier(0.15, 1, 0.3, 1)

  &:hover
    border 1px solid #000
    filter brightness(1.15)

    &::before
      background-size 22px

  &:active
    box-shadow inset 0 4px 12px #00000026, inset 0 -2px 4px #ffffffcc, inset 0 0 0 1px #0000000d
    transform scale(0.975) translateY(0)
    transition 0.1s