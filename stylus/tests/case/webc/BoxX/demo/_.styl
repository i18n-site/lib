@import '../../Lg/_.styl'
@import '../../Btn/_.styl'

.demo-section
  box-sizing border-box
  display flex
  flex-direction column
  gap 20px
  margin 40px auto
  max-width 600px
  padding 32px
  width 100%

  .demo-header
    display flex
    justify-content flex-end
    width 100%

  h2
    color #1d1d1f
    font-size 18px
    font-weight 600
    text-align center

.btn-group
  display flex
  flex-wrap wrap
  gap 16px
  justify-content center

dialog.Box form.Lg
  align-items flex-start
  border-radius 16px
  display flex
  flex-direction column
  gap 12px
  max-width 600px
  min-width 280px
  padding 24px

  h3
    color #1d1d1f
    font-size 18px
    font-weight 600
    margin 0

  p
    color #666
    font-size 16px
    line-height 1.5
    margin 0