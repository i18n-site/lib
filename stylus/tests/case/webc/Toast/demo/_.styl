@import '../../Lg/_.styl'
@import '../../Btn/_.styl'

.demo-section
  box-sizing border-box
  display flex
  flex-direction column
  gap 20px
  margin 40px auto
  max-width 600px
  padding 32px
  width 100%

  h2
    color #1d1d1f
    font-size 18px
    font-weight 600
    text-align center

  label
    align-items center
    color #666
    display flex
    font-size 14px
    gap 8px
    justify-content center

    input
      border 1px solid #d1d1d6
      border-radius 8px
      box-sizing border-box
      font-size 14px
      height 36px
      outline none
      padding 8px 12px
      text-align center
      width 80px

      &:focus
        border-color #0071e3

.btn-group
  align-items center
  display flex
  flex-wrap wrap
  gap 16px
  justify-content center